# Copy to .env and fill in real values. .env is gitignored — NEVER commit real keys.

# --- LLM (answer generation) ---
# Which provider is active is set in src/config.py (LLMConfig.provider).
# Default config uses DeepSeek (OpenAI-compatible API), so only this is required:
DEEPSEEK_API_KEY=
# To switch LLMConfig.provider to "openai" or "anthropic" later, fill the matching key:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OpenSearch (local Docker) ---
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=
